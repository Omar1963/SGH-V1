{
    "env": {
        "browser": true,
        "es2021": true
    },
    "globals": {
        "bootstrap": "readonly"
    },
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": [
            "warn",
            {
                "varsIgnorePattern": "^[A-Z_]",
                "argsIgnorePattern": "^_"
            }
        ],
        "no-undef": "error"
    }
}